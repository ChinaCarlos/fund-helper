{
  "name": "fund-helper",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "./start.sh",
    "dev:web": "pnpm --filter fund-helper-web dev",
    "dev:chrome": "pnpm --filter fund-helper-extension dev",
    "dev:desktop": "pnpm --filter fund-helper-desktop tauri:dev",
    "build:web": "pnpm --filter fund-helper-web build",
    "build:chrome": "pnpm --filter fund-helper-extension build",
    "build:vscode": "pnpm --filter fund-helper-vscode build",
    "build:desktop": "pnpm --filter fund-helper-desktop tauri:build",
    "dev:docs": "pnpm --filter fund-helper-docs dev",
    "build:docs": "pnpm --filter fund-helper-docs build",
    "preview:docs": "pnpm --filter fund-helper-docs preview",
    "install:all": "pnpm install",
    "version:list": "node scripts/version.mjs list",
    "version:sync": "node scripts/version.mjs sync",
    "version:get": "node scripts/version.mjs get",
    "version:set": "node scripts/version.mjs set",
    "version:bump": "node scripts/version.mjs bump",
    "release:extensions": "node scripts/release.mjs",
    "release:chrome": "./publish-chrome.sh",
    "release:vscode": "./publish-vscode.sh"
  }
}
